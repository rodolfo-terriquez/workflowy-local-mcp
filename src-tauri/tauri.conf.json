{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workflowy MCP",
  "version": "1.4.3",
  "identifier": "com.workflowy.local-mcp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run build:mcp",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Workflowy MCP",
        "width": 900,
        "height": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "copyright": "Copyright © 2026 Rodolfo Terriquez",
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../dist-mcp/**/*"],
    "externalBin": []
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/rodolfo-terriquez/workflowy-local-mcp/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCMzcyODA5Rjc1NUQ2MDMKUldRRDFsWDNDU2czcStBQ2xDaW9udVRtMEtQQkdvL3hsYS9DOVZNY2YxaE9PeU9hNGxTcWRmOXUK"
    }
  }
}
